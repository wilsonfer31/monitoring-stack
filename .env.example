# Nom du projet Docker Compose à surveiller
# = valeur de com.docker.compose.project sur tes containers
# Par défaut : le nom du dossier racine du projet en minuscules
COMPOSE_PROJECT=mon-projet

# Regex des containers à afficher dans les dashboards
# Exemples :
#   mon-projet-.+        → tous les containers du projet
#   backend|frontend|db  → uniquement ces trois
CONTAINER_FILTER=mon-projet-.+

# Mot de passe admin Grafana
GRAFANA_PASSWORD=admin
