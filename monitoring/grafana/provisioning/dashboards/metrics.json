{
  "title": "Métriques système",
  "uid": "app-metrics",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "RAM utilisée par container",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name=~\".+\"} / 1024 / 1024",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "MiB" } }
    },
    {
      "id": 2,
      "title": "CPU par container (%)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name=~\".+\"}[1m]) * 100",
          "legendFormat": "{{name}}",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 3,
      "title": "RAM hôte (%)",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "steps": [
            { "value": 0,  "color": "green" },
            { "value": 70, "color": "yellow" },
            { "value": 85, "color": "red" }
          ]}
        }
      }
    },
    {
      "id": 4,
      "title": "Disque hôte (%)",
      "type": "gauge",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(1 - (node_filesystem_avail_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!=\"tmpfs\"})) * 100",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "steps": [
            { "value": 0,  "color": "green" },
            { "value": 75, "color": "yellow" },
            { "value": 90, "color": "red" }
          ]}
        }
      }
    },
    {
      "id": 5,
      "title": "Charge CPU hôte (1min)",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "node_load1", "refId": "E" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [
            { "value": 0, "color": "green" },
            { "value": 2, "color": "yellow" },
            { "value": 4, "color": "red" }
          ]}
        }
      }
    }
  ]
}
