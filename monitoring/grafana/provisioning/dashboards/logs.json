{
  "title": "Logs applicatifs",
  "uid": "app-logs",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "container",
        "type": "query",
        "label": "Container",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": "label_values(container)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Logs en temps réel",
      "type": "logs",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{container=~\"$container\"}",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 2,
      "title": "Erreurs (ERROR / WARN)",
      "type": "logs",
      "gridPos": { "x": 0, "y": 10, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{container=~\"$container\"} |~ \"ERROR|WARN\"",
          "refId": "B"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 3,
      "title": "Volume de logs par container",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 18, "w": 24, "h": 7 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (container) (rate({container=~\"$container\"}[1m]))",
          "legendFormat": "{{container}}",
          "refId": "C"
        }
      ]
    }
  ]
}
